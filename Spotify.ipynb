        "for col in numerical_cols:\n",
        "    Q1 = df[col].quantile(0.25)\n",
        "    Q3 = df[col].quantile(0.75)\n",
        "    IQR = Q3 - Q1\n",
        "\n",
        "    lower_bound_iqr = Q1 - 1.5 * IQR\n",
        "    upper_bound_iqr = Q3 + 1.5 * IQR\n",
        "\n",
        "    outliers_iqr = df[(df[col] < lower_bound_iqr) | (df[col] > upper_bound_iqr)]\n",
        "\n",
        "    print(f\"\\nColumn: {col} (IQR Method)\")\n",
        "    print(f\"  Q1: {Q1:.2f}, Q3: {Q3:.2f}, IQR: {IQR:.2f}\")\n",
        "    print(f\"  Lower Bound: {lower_bound_iqr:.2f}, Upper Bound: {upper_bound_iqr:.2f}\")\n",
        "    print(f\"  Number of outliers: {len(outliers_iqr)}\")\n",
        "    if len(outliers_iqr) > 0:\n",
        "        print(\"  Outliers (first 5):\")\n",
        "        display(outliers_iqr[[col]].head())"
      ]
