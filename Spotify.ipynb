      "source": [
        "import musicbrainzngs as mb\n",
        "import time\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import json\n",
        "import os\n",
        "from tqdm.notebook import tqdm # Import tqdm for progress bar\n",
        "\n",
        "# Set user agent for MusicBrainz API\n",
        "mb.set_useragent(\"ColabDataAnalysisApp\", \"1.0\", \"gareevaazalia12@gmail.com\")\n",
        "\n",
        "# --- Cache for Album Information ---\n",
        "CACHE_FILE = 'musicbrainz_cache.json'\n",
        "\n",
        "def load_cache():\n",
        "    \"\"\"Loads the album cache from a JSON file.\"\"\"\n",
        "    if os.path.exists(CACHE_FILE):\n",
        "        with open(CACHE_FILE, 'r') as f:\n",
        "            loaded_cache = json.load(f)\n",
        "            # Convert string 'nan' back to np.nan if necessary (None in JSON -> np.nan in Python)\n",
        "            return {k: (v[0], v[1], v[2], (np.nan if v[3] is None else v[3]), v[4]) for k, v in loaded_cache.items()}\n",
        "    return {}\n",
        "\n",
        "def save_cache(cache_data):\n",
        "    \"\"\"Saves the album cache to a JSON file.\"\"\"\n",
        "    # Convert np.nan to None for JSON serialization\n",
        "    serializable_cache = {k: (v[0], v[1], v[2], (None if pd.isna(v[3]) else v[3]), v[4]) for k, v in cache_data.items()}\n",
        "    with open(CACHE_FILE, 'w') as f:\n",
        "        json.dump(serializable_cache, f, indent=4)\n",
        "\n",
        "\n",
        "def get_musicbrainz_album_info(artist_name, album_title, cache):\n",
        "    \"\"\"\n",
        "    Fetches release metadata (country, status, label, year) for an album from MusicBrainz.\n",
        "    Handles API rate limits, uses a cache, and returns default values if no information is found.\n",
        "    \"\"\"\n",
        "    cache_key = f\"{artist_name}|{album_title}\"\n",
        "\n",
        "    if cache_key in cache:\n",
        "        return cache[cache_key]\n",
        "\n",
        "    retries = 3\n",
        "    for attempt in range(retries):\n",
        "        try:\n",
        "            time.sleep(1) # Adhere to MusicBrainz API rate limit (1 request per second)\n",
        "            result = mb.search_releases(artist=artist_name, release=album_title, limit=1)\n",
        "\n",
        "            country, status, label, year, has_data = 'unknown', 'unknown', 'unknown', np.nan, 0\n",
        "\n",
        "            if result and result['release-list']:\n",
        "                release = result['release-list'][0]\n",
        "                country = release.get('country', 'unknown')\n",
        "                status = release.get('status', 'unknown')\n",
        "\n",
        "                if 'label-info' in release and release['label-info']:\n",
        "                    label = release['label-info'][0].get('label', {}).get('name', 'unknown')\n",
        "\n",
        "                if 'date' in release and release['date']:\n",
        "                    try:\n",
        "                        year = int(release['date'].split('-')[0])\n",
        "                    except ValueError:\n",
        "                        pass # year remains NaN if parsing fails\n",
        "                has_data = 1 # Data found\n",
        "\n",
        "            # Store result in cache before returning\n",
        "            cache[cache_key] = (country, status, label, year, has_data)\n",
        "            return country, status, label, year, has_data\n",
        "\n",
        "        except mb.WebServiceError as e:\n",
        "            print(f\"MusicBrainz API error for {artist_name} - {album_title} (attempt {attempt+1}/{retries}): {e}\")\n",
        "            if attempt < retries - 1:\n",
        "                time.sleep(5) # Wait longer before retrying\n",
        "            else:\n",
        "                # After all retries fail, store and return defaults\n",
        "                cache[cache_key] = ('unknown', 'unknown', 'unknown', np.nan, 0)\n",
        "                return 'unknown', 'unknown', 'unknown', np.nan, 0\n",
        "        except Exception as e:\n",
        "            print(f\"An unexpected error occurred for {artist_name} - {album_title}: {e}\")\n",
        "            # Store and return defaults for unexpected errors\n",
        "            cache[cache_key] = ('unknown', 'unknown', 'unknown', np.nan, 0)\n",
        "            return 'unknown', 'unknown', 'unknown', np.nan, 0\n",
        "\n",
        "    # Fallback if all retries fail\n",
        "    cache[cache_key] = ('unknown', 'unknown', 'unknown', np.nan, 0)\n",
        "    return 'unknown', 'unknown', 'unknown', np.nan, 0\n",
        "\n",
        "\n",
        "# Ensure the necessary album columns exist before trying to update them\n",
        "if 'release_country' not in df.columns:\n",
        "    df['release_country'] = 'unknown'\n",
        "if 'release_status' not in df.columns:\n",
        "    df['release_status'] = 'unknown'\n",
        "if 'release_label' not in df.columns:\n",
        "    df['release_label'] = 'unknown'\n",
        "if 'album_year' not in df.columns:\n",
        "    df['album_year'] = np.nan\n",
        "if 'has_musicbrainz_data' not in df.columns:\n",
        "    df['has_musicbrainz_data'] = 0\n",
        "\n",
        "# Create a temporary DataFrame of unique artist-album pairs to reduce redundant API calls\n",
        "unique_albums_df = df[['artists', 'album']].drop_duplicates().copy()\n",
        "\n",
        "# Load existing album cache\n",
        "musicbrainz_album_cache = load_cache()\n",
        "print(f\"Loaded {len(musicbrainz_album_cache)} items from album cache.\")\n",
        "\n",
        "# Initialize columns in unique_albums_df DataFrame to store fetched data\n",
        "unique_albums_df['mb_release_country'] = 'unknown'\n",
        "unique_albums_df['mb_release_status'] = 'unknown'\n",
        "unique_albums_df['mb_release_label'] = 'unknown'\n",
        "unique_albums_df['mb_album_year'] = np.nan\n",
        "unique_albums_df['mb_has_data'] = 0\n",
        "\n",
        "print(f\"Fetching MusicBrainz album data for {len(unique_albums_df)} unique album-artist pairs...\")\n",
        "\n",
        "processed_album_count = 0\n",
        "# Apply the function to each unique album, checking cache first\n",
        "for index, row in tqdm(unique_albums_df.iterrows(), total=len(unique_albums_df), desc=\"Fetching Album Data\"):\n",
        "    country, status, label, year, has_data = get_musicbrainz_album_info(row['artists'], row['album'], musicbrainz_album_cache)\n",
        "\n",
        "    unique_albums_df.loc[index, 'mb_release_country'] = country\n",
        "    unique_albums_df.loc[index, 'mb_release_status'] = status\n",
        "    unique_albums_df.loc[index, 'mb_release_label'] = label\n",
        "    unique_albums_df.loc[index, 'mb_album_year'] = year\n",
        "    unique_albums_df.loc[index, 'mb_has_data'] = has_data\n",
        "\n",
        "    processed_album_count += 1\n",
        "    if processed_album_count % 100 == 0: # Save cache periodically\n",
        "        save_cache(musicbrainz_album_cache)\n",
        "        # print(f\"Processed {processed_album_count} albums. Album cache saved.\") # Removed to avoid cluttering with tqdm\n",
        "\n",
        "# Save the cache one last time after the loop completes\n",
        "save_cache(musicbrainz_album_cache)\n",
        "print(f\"\\nAll {processed_album_count} albums processed. Final album cache saved.\")\n",
        "\n",
        "# Merge the fetched album data back to the original DataFrame\n",
        "df = df.merge(unique_albums_df, on=['artists', 'album'], how='left', suffixes=('', '_mb_album'))\n",
        "\n",
        "# Update the original df columns with the new fetched data (only if mb_has_data is 1)\n",
        "df['release_country'] = np.where(df['mb_has_data'] == 1, df['mb_release_country'], df['release_country'])\n",
        "df['release_status'] = np.where(df['mb_has_data'] == 1, df['mb_release_status'], df['release_status'])\n",
        "df['release_label'] = np.where(df['mb_has_data'] == 1, df['mb_release_label'], df['release_label'])\n",
        "df['album_year'] = np.where(df['mb_has_data'] == 1, df['mb_album_year'], df['album_year'])\n",
        "df['has_musicbrainz_data'] = np.where(df['mb_has_data'] == 1, 1, df['has_musicbrainz_data'])\n",
        "\n",
        "# Drop the temporary album columns created during the merge\n",
        "df = df.drop(columns=['mb_release_country', 'mb_release_status', 'mb_release_label', 'mb_album_year', 'mb_has_data'])\n",
        "\n",
        "\n",
        "# --- New Artist Information Fetching ---\n",
        "ARTIST_CACHE_FILE = 'musicbrainz_artist_cache.json'\n",
        "\n",
        "def load_artist_cache():\n",
        "    \"\"\"Loads the artist cache from a JSON file.\"\"\"\n",
        "    if os.path.exists(ARTIST_CACHE_FILE):\n",
        "        with open(ARTIST_CACHE_FILE, 'r') as f:\n",
        "            loaded_cache = json.load(f)\n",
        "            # Convert string 'nan' back to np.nan (None in JSON -> np.nan in Python)\n",
        "            return {k: (v[0], v[1], (np.nan if v[2] is None else v[2]), (np.nan if v[3] is None else v[3]), v[4], v[5]) for k, v in loaded_cache.items()}\n",
        "    return {}\n",
        "\n",
        "def save_artist_cache(cache_data):\n",
        "    \"\"\"Saves the artist cache to a JSON file.\"\"\"\n",
        "    # Convert np.nan to None for JSON serialization\n",
        "    serializable_cache = {k: (v[0], v[1], (None if pd.isna(v[2]) else v[2]), (None if pd.isna(v[3]) else v[3]), v[4], v[5]) for k, v in cache_data.items()}\n",
        "    with open(ARTIST_CACHE_FILE, 'w') as f:\n",
        "        json.dump(serializable_cache, f, indent=4)\n",
        "\n",
        "def get_musicbrainz_artist_details(artist_name, artist_cache):\n",
        "    \"\"\"\n",
        "    Fetches artist metadata (type, country, career dates) from MusicBrainz.\n",
        "    Handles API rate limits, uses a cache, and returns default values if no information is found.\n",
        "    \"\"\"\n",
        "    cache_key = artist_name\n",
        "    if cache_key in artist_cache:\n",
        "        return artist_cache[cache_key]\n",
        "\n",
        "    # Take the first artist if there's a comma-separated list for lookup simplicity\n",
        "    primary_artist = artist_name.split(',')[0].strip()\n",
        "\n",
        "    retries = 3\n",
        "    for attempt in range(retries):\n",
        "        try:\n",
        "            time.sleep(1) # Adhere to MusicBrainz API rate limit\n",
        "            result = mb.search_artists(artist=primary_artist, limit=1)\n",
        "\n",
        "            artist_type, country, begin_year, end_year, is_active, has_data = 'unknown', 'unknown', np.nan, np.nan, False, 0\n",
        "\n",
        "            if result and result['artist-list']:\n",
        "                artist = result['artist-list'][0]\n",
        "                artist_type = artist.get('type', 'unknown')\n",
        "                country = artist.get('country', 'unknown')\n",
        "\n",
        "                if 'life-span' in artist:\n",
        "                    begin_date = artist['life-span'].get('begin')\n",
        "                    if begin_date:\n",
        "                        try:\n",
        "                            begin_year = int(begin_date.split('-')[0])\n",
        "                        except ValueError:\n",
        "                            pass\n",
        "                    end_date = artist['life-span'].get('end')\n",
        "                    if end_date:\n",
        "                        try:\n",
        "                            end_year = int(end_date.split('-')[0])\n",
        "                        except ValueError:\n",
        "                            pass\n",
        "                # An artist is considered active if no end date or end date is in the future/current year, and a begin year is known.\n",
        "                is_active = (pd.isna(end_year) or (not pd.isna(end_year) and end_year >= pd.Timestamp.now().year)) and not pd.isna(begin_year)\n",
        "                has_data = 1\n",
        "\n",
        "            artist_cache[cache_key] = (artist_type, country, begin_year, end_year, is_active, has_data)\n",
        "            return artist_type, country, begin_year, end_year, is_active, has_data\n",
        "\n",
        "        except mb.WebServiceError as e:\n",
        "            print(f\"MusicBrainz API error for artist {primary_artist} (attempt {attempt+1}/{retries}): {e}\")\n",
        "            if attempt < retries - 1:\n",
        "                time.sleep(5)\n",
        "            else:\n",
        "                artist_cache[cache_key] = ('unknown', 'unknown', np.nan, np.nan, False, 0)\n",
        "                return 'unknown', 'unknown', np.nan, np.nan, False, 0\n",
        "        except Exception as e:\n",
        "            print(f\"An unexpected error occurred for artist {primary_artist}: {e}\")\n",
        "            artist_cache[cache_key] = ('unknown', 'unknown', np.nan, np.nan, False, 0)\n",
        "            return 'unknown', 'unknown', np.nan, np.nan, False, 0\n",
        "    artist_cache[cache_key] = ('unknown', 'unknown', np.nan, np.nan, False, 0)\n",
        "    return 'unknown', 'unknown', np.nan, np.nan, False, 0\n",
        "\n",
        "# Add new artist columns to df if they don't exist\n",
        "if 'artist_type' not in df.columns:\n",
        "    df['artist_type'] = 'unknown'\n",
        "if 'artist_country' not in df.columns:\n",
        "    df['artist_country'] = 'unknown'\n",
        "if 'artist_begin_year' not in df.columns:\n",
        "    df['artist_begin_year'] = np.nan\n",
        "if 'artist_end_year' not in df.columns:\n",
        "    df['artist_end_year'] = np.nan\n",
        "if 'artist_is_active' not in df.columns:\n",
        "    df['artist_is_active'] = False\n",
        "if 'has_musicbrainz_artist_data' not in df.columns:\n",
        "    df['has_musicbrainz_artist_data'] = 0\n",
        "\n",
        "# Get unique artists to fetch details for\n",
        "unique_artists_df = df[['artists']].drop_duplicates().copy()\n",
        "unique_artists_df['mb_artist_type'] = 'unknown'\n",
        "unique_artists_df['mb_artist_country'] = 'unknown'\n",
        "unique_artists_df['mb_artist_begin_year'] = np.nan\n",
        "unique_artists_df['mb_artist_end_year'] = np.nan\n",
        "unique_artists_df['mb_artist_is_active'] = False\n",
        "unique_artists_df['mb_has_artist_data'] = 0\n",
        "\n",
        "artist_cache = load_artist_cache()\n",
        "print(f\"Loaded {len(artist_cache)} items from artist cache.\")\n",
        "\n",
        "print(f\"Fetching MusicBrainz artist data for {len(unique_artists_df)} unique artists...\")\n",
        "\n",
        "processed_artist_count = 0\n",
        "for index, row in tqdm(unique_artists_df.iterrows(), total=len(unique_artists_df), desc=\"Fetching Artist Data\"):\n",
        "    artist_type, country, begin_year, end_year, is_active, has_data = get_musicbrainz_artist_details(row['artists'], artist_cache)\n",
        "    unique_artists_df.loc[index, 'mb_artist_type'] = artist_type\n",
        "    unique_artists_df.loc[index, 'mb_artist_country'] = country\n",
        "    unique_artists_df.loc[index, 'mb_artist_begin_year'] = begin_year\n",
        "    unique_artists_df.loc[index, 'mb_artist_end_year'] = end_year\n",
        "    unique_artists_df.loc[index, 'mb_artist_is_active'] = is_active\n",
        "    unique_artists_df.loc[index, 'mb_has_artist_data'] = has_data\n",
        "\n",
        "    processed_artist_count += 1\n",
        "    if processed_artist_count % 50 == 0: # Save cache periodically\n",
        "        save_artist_cache(artist_cache)\n",
        "        # print(f\"Processed {processed_artist_count} artists. Artist cache saved.\") # Removed to avoid cluttering with tqdm\n",
        "\n",
        "save_artist_cache(artist_cache)\n",
        "print(f\"\\nAll {processed_artist_count} artists processed. Final artist cache saved.\")\n",
        "\n",
        "# Merge artist data back to the main DataFrame\n",
        "df = df.merge(unique_artists_df, on='artists', how='left', suffixes=('', '_mb_artist'))\n",
        "\n",
        "# Update original df artist columns with fetched data (only if mb_has_artist_data is 1)\n",
        "df['artist_type'] = np.where(df['mb_has_artist_data'] == 1, df['mb_artist_type'], df['artist_type'])\n",
        "df['artist_country'] = np.where(df['mb_has_artist_data'] == 1, df['mb_artist_country'], df['artist_country'])\n",
        "df['artist_begin_year'] = np.where(df['mb_has_artist_data'] == 1, df['mb_artist_begin_year'], df['artist_begin_year'])\n",
        "df['artist_end_year'] = np.where(df['mb_has_artist_data'] == 1, df['mb_artist_end_year'], df['artist_end_year'])\n",
        "df['artist_is_active'] = np.where(df['mb_has_artist_data'] == 1, df['mb_artist_is_active'], df['artist_is_active'])\n",
        "df['has_musicbrainz_artist_data'] = np.where(df['mb_has_artist_data'] == 1, 1, df['has_musicbrainz_artist_data'])\n",
        "\n",
        "# Drop temporary artist merge columns\n",
        "df = df.drop(columns=['mb_artist_type', 'mb_artist_country', 'mb_artist_begin_year', 'mb_artist_end_year', 'mb_artist_is_active', 'mb_has_artist_data'])\n",
        "\n",
        "# Calculate artist career duration (стаж) if begin year is known\n",
        "df['artist_career_duration_years'] = np.where(\n",
        "    df['has_musicbrainz_artist_data'] == 1,\n",
        "    np.where(\n",
        "        df['artist_begin_year'].notna(),\n",
        "        (df['artist_end_year'].fillna(pd.Timestamp.now().year) - df['artist_begin_year']),\n",
        "        np.nan\n",
        "    ),\n",
        "    np.nan\n",
        ")\n",
        "# If start and end are same year, or if it's active and current year is start year, duration might be 0, replace with nan if desired.\n",
        "df['artist_career_duration_years'] = df['artist_career_duration_years'].replace(0, np.nan)\n",
        "\n",
        "print(\"\\nMusicBrainz album and artist data fetching and merging complete.\")\n",
        "print(\"Updated DataFrame info with all new details:\")\n",
        "df.info()\n",
        "print(\"\\nFirst 5 rows with updated MusicBrainz data (album and artist):\")\n",
        "display(df[['artists', 'album', 'release_country', 'release_status', 'release_label', 'album_year', 'has_musicbrainz_data', \\\n",
        "            'artist_type', 'artist_country', 'artist_begin_year', 'artist_end_year', 'artist_is_active', 'artist_career_duration_years', 'has_musicbrainz_artist_data']].head())"
      ]
    },
