      "source": [
        "import lime\n",
        "import lime.lime_tabular\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# 1. Находим экземпляр с наибольшей ошибкой в тестовом наборе\n",
        "errors = abs(y_test - y_test_pred_svm)\n",
        "max_error_idx_in_test_subset = errors.idxmax() # Индекс из исходного df_final_selected\n",
        "\n",
        "# Получаем соответствующую строку из X_test и фактические/предсказанные значения\n",
        "instance_to_explain = X_test.loc[max_error_idx_in_test_subset]\n",
        "actual_value = y_test.loc[max_error_idx_in_test_subset]\n",
        "predicted_value = svm_model.predict(instance_to_explain.to_frame().T)[0]\n",
        "\n",
        "print(f\"Индекс экземпляра с наибольшей ошибкой в тестовом наборе: {max_error_idx_in_test_subset}\")\n",
        "print(f\"Фактическое значение популярности: {actual_value:.2f}\")\n",
        "print(f\"Предсказанное значение популярности: {predicted_value:.2f}\")\n",
        "print(f\"Абсолютная ошибка: {abs(actual_value - predicted_value):.2f}\")\n",
        "\n",
        "# 2. Подготовка данных для LIME Explainer\n",
        "feature_names = X_train.columns.tolist()\n",
        "\n",
        "# Определяем индексы категориальных признаков. Для LIME все one-hot закодированные\n",
        "# столбцы и бинарные (0/1) столбцы рассматриваются как категориальные.\n",
        "# В нашем случае большинство int64 столбцов являются бинарными (OHE или булевы).\n",
        "categorical_features_indices = [i for i, col in enumerate(X_train.columns) if X_train[col].dtype == 'int64']\n",
        "\n",
        "# Инициализация LIME explainer\n",
        "explainer = lime.lime_tabular.LimeTabularExplainer(\n",
        "    training_data=X_train.values, # Обучающие данные для понимания распределения признаков\n",
        "    feature_names=feature_names,\n",
        "    class_names=['popularity_capped'], # Целевое имя для контекста регрессии\n",
        "    categorical_features=categorical_features_indices,\n",
        "    mode='regression',\n",
        "    discretize_continuous=True # Дискретизация непрерывных признаков для лучшего объяснения\n",
        ")\n",
        "\n",
        "# 3. Генерация LIME объяснения для выбранного экземпляра\n",
        "num_features_to_show = 10 # Количество признаков для отображения в объяснении\n",
        "print(f\"\\nГенерация LIME объяснения для экземпляра {max_error_idx_in_test_subset}...\")\n",
        "explanation = explainer.explain_instance(\n",
        "    data_row=instance_to_explain.values,\n",
        "    predict_fn=svm_model.predict,\n",
        "    num_features=num_features_to_show\n",
        ")\n",
        "\n",
        "print(\"\\nLIME объяснение (топ-10 признаков):\")\n",
        "for feature, weight in explanation.as_list():\n",
        "    print(f\"- {feature}: {weight:.4f}\")\n",
        "\n",
        "# 4. Визуализация LIME объяснения\n",
        "print(\"\\nВизуализация LIME объяснения...\")\n",
        "plt.figure(figsize=(12, 8))\n",
        "explanation.as_pyplot_figure()\n",
        "plt.title(f\"LIME Explanation for instance {max_error_idx_in_test_subset} (Actual: {actual_value:.2f}, Predicted: {predicted_value:.2f})\")\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
