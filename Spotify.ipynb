        "### Сравнение результатов всех трёх моделей\n",
        "\n",
        "Давайте сравним метрики производительности (MSE и R-squared) и коэффициенты для всех трех обученных линейных моделей: Стандартной Линейной Регрессии, Ridge и Lasso."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 1000
        },
        "id": "33576c6b",
        "outputId": "be7e8993-43db-42a8-9bd2-4429d07c3293"
      },
      "source": [
        "print(\"### Сводка по метрикам производительности ###\\n\")\n",
        "\n",
        "print(\"**Линейная Регрессия:**\")\n",
        "print(f\"  MSE (Train): {mse_train:.4f}, RMSE (Train): {rmse_train:.4f}, R2 (Train): {r2_train:.4f}\")\n",
        "print(f\"  MSE (Test): {mse_test:.4f}, RMSE (Test): {rmse_test:.4f}, R2 (Test): {r2_test:.4f}\")\n",
        "\n",
        "print(\"\\n**Ridge Регрессия:**\")\n",
        "print(f\"  MSE (Train): {mse_train_ridge:.4f}, RMSE (Train): {rmse_train_ridge:.4f}, R2 (Train): {r2_train_ridge:.4f}\")\n",
        "print(f\"  MSE (Test): {mse_test_ridge:.4f}, RMSE (Test): {rmse_test_ridge:.4f}, R2 (Test): {r2_test_ridge:.4f}\")\n",
        "\n",
        "print(\"\\n**Lasso Регрессия:**\")\n",
        "print(f\"  MSE (Train): {mse_train_lasso:.4f}, RMSE (Train): {rmse_train_lasso:.4f}, R2 (Train): {r2_train_lasso:.4f}\")\n",
        "print(f\"  MSE (Test): {mse_test_lasso:.4f}, RMSE (Test): {rmse_test_lasso:.4f}, R2 (Test): {r2_test_lasso:.4f}\")\n",
        "\n",
        "print(\"\\n\\n### Сравнение Коэффициентов Моделей ###\\n\")\n",
        "\n",
        "# Объединяем коэффициенты в один DataFrame для удобства сравнения\n",
        "all_coefficients_df = pd.DataFrame({'Feature': X.columns})\n",
        "all_coefficients_df['Linear Regression Coef'] = linear_model.coef_\n",
        "all_coefficients_df['Ridge Coef (alpha=1.0)'] = ridge_model.coef_\n",
        "all_coefficients_df['Lasso Coef (alpha=0.01)'] = lasso_model.coef_\n",
        "\n",
        "display(all_coefficients_df)\n",
        "\n",
        "print(f\"\\nИнтерсепт Линейной Регрессии: {linear_model.intercept_:.4f}\")\n",
        "print(f\"Интерсепт Ridge Регрессии: {ridge_model.intercept_:.4f}\")\n",
        "print(f\"Интерсепт Lasso Регрессии: {lasso_model.intercept_:.4f}\")"
      ],
