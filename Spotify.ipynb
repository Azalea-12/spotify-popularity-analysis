    {
      "cell_type": "code",
      "source": [
        "# Capping for 'popularity'\n",
        "# Note: popularity has NaNs, which need to be handled. Capping will ignore NaNs by default.\n",
        "Q1_popularity = df['popularity'].quantile(0.25)\n",
        "Q3_popularity = df['popularity'].quantile(0.75)\n",
        "IQR_popularity = Q3_popularity - Q1_popularity\n",
        "\n",
        "lower_bound_popularity = Q1_popularity - 1.5 * IQR_popularity\n",
        "upper_bound_popularity = Q3_popularity + 1.5 * IQR_popularity\n",
        "\n",
        "print(f\"\\nOriginal 'popularity' - Q1: {Q1_popularity:.2f}, Q3: {Q3_popularity:.2f}, IQR: {IQR_popularity:.2f}\")\n",
        "print(f\"Lower Bound for Capping: {lower_bound_popularity:.2f}, Upper Bound for Capping: {upper_bound_popularity:.2f}\")\n",
        "\n",
        "df['popularity_capped'] = df['popularity'].clip(lower=lower_bound_popularity, upper=upper_bound_popularity)\n",
        "\n",
        "print(\"\\nDescriptive statistics for 'popularity' after capping:\")\n",
        "display(df[['popularity', 'popularity_capped']].describe())\n",
        "\n",
        "# Visualize 'popularity' after capping\n",
        "plt.figure(figsize=(10, 6))\n",
        "sns.boxplot(y=df['popularity_capped'])\n",
        "plt.title('Box Plot of Popularity (After Outlier Capping)')\n",
        "plt.ylabel('Popularity (Capped)')\n",
        "plt.show()\n",
        "\n",
        "print(f\"Number of values changed due to capping in 'popularity': {(df['popularity'] != df['popularity_capped']).sum()}\")"
      ],
