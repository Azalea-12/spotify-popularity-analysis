      "source": [
        "### Identifying and Transforming Categorical Variables"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "14def44c",
        "outputId": "b0ab1ff1-4aed-4a8d-c997-59c27e1648a3"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Categorical columns identified: ['name', 'artists', 'album', 'explicit', 'release_country', 'release_status', 'release_label', 'artist_type', 'artist_country', 'artist_is_active', 'super_genre']\n"
          ]
        }
      ],
      "source": [
        "# Identify categorical columns\n",
        "categorical_cols = df.select_dtypes(include=['object', 'bool']).columns\n",
        "print(\"Categorical columns identified:\", list(categorical_cols))"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "e5da161a"
      },
      "source": [
        "### One-Hot Encoding Categorical Features\n",
        "\n",
        "Применим One-Hot Encoding к категориальным признакам, чтобы преобразовать их в числовой формат, подходящий для моделей машинного обучения."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 718
        },
        "id": "c7f6b7b1",
        "outputId": "e1ac6133-b96b-4dc9-d42b-1035f19bbf7e"
      },
      "source": [
        "# Определяем категориальные столбцы, которые нужно закодировать.\n",
        "# 'explicit' и 'artist_is_active' уже булевы, поэтому их можно просто преобразовать в int.\n",
        "categorical_to_encode = [\n",
        "    'release_country', 'release_status', 'release_label', 'artist_type', 'artist_country', 'super_genre'\n",
        "]\n",
        "\n",
        "# Для начала, преобразуем булевы столбцы в int (0 или 1), если они не были преобразованы ранее.\n",
        "# Проверим, существуют ли столбцы и имеют ли они тип bool, прежде чем пытаться преобразовать.\n",
        "if 'explicit' in df.columns and df['explicit'].dtype == 'bool':\n",
        "    df['explicit'] = df['explicit'].astype(int)\n",
        "    print(\"Столбец 'explicit' преобразован в int.\")\n",
        "\n",
        "if 'artist_is_active' in df.columns and df['artist_is_active'].dtype == 'bool':\n",
        "    df['artist_is_active'] = df['artist_is_active'].astype(int)\n",
        "    print(\"Столбец 'artist_is_active' преобразован в int.\")\n",
        "\n",
        "# Применяем One-Hot Encoding к выбранным категориальным столбцам\n",
        "df_encoded = pd.get_dummies(df, columns=categorical_to_encode, drop_first=True, dtype=int)\n",
        "\n",
        "print(f\"Преобразовано {len(categorical_to_encode)} категориальных столбцов.\")\n",
        "print(\"Размер датасета после One-Hot Encoding:\", df_encoded.shape)\n",
        "\n",
        "print(\"\\nПервые 5 строк обновленного датасета (с некоторыми закодированными столбцами):\")\n",
        "display(df_encoded.head())\n",
        "\n",
        "print(\"\\nИнформация о датасете после кодирования:\")\n",
        "df_encoded.info()\n"
      ],
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
