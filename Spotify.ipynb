    {
      "cell_type": "code",
      "source": [
        "import shap\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import pandas as pd\n",
        "\n",
        "# 1. ИСПРАВЛЕНО: Увеличиваем фоновый датасет для стабильности\n",
        "background_size = 100  # Увеличиваем с 50 до 100\n",
        "X_background = X_train.sample(n=background_size, random_state=42)\n",
        "\n",
        "print(f\"Инициализация SHAP KernelExplainer с {background_size} фоновыми образцами...\")\n",
        "\n",
        "# 2. ИСПРАВЛЕНО: Явно указываем функцию предсказания\n",
        "def predict_wrapper(x):\n",
        "    \"\"\"Обертка для predict, которая обрабатывает pandas DataFrame\"\"\"\n",
        "    if isinstance(x, pd.DataFrame):\n",
        "        return svm_model.predict(x)\n",
        "    return svm_model.predict(x)\n",
        "\n",
        "explainer = shap.KernelExplainer(\n",
        "    predict_wrapper,\n",
        "    X_background,\n",
        "    link=\"identity\"  # Для регрессии\n",
        ")\n",
        "\n",
        "# 3. Уменьшаем размер тестовой выборки для ускорения\n",
        "sample_size = 50  # Уменьшаем для скорости\n",
        "X_test_sample = X_test.sample(n=sample_size, random_state=42)\n",
        "\n",
        "print(\"Вычисление SHAP значений... Это может занять 5-10 минут...\")\n",
        "shap_values = explainer.shap_values(X_test_sample, nsamples=100)  # Уменьшаем nsamples для скорости\n",
        "\n",
        "print(f\"SHAP значения вычислены! Форма: {np.array(shap_values).shape}\")\n",
        "\n",
        "# Проверка: есть ли ненулевые SHAP значения?\n",
        "if np.all(np.abs(shap_values) < 1e-6):\n",
        "    print(\"⚠️ ВНИМАНИЕ: Все SHAP значения близки к нулю!\")\n",
        "    print(\"Модель SVR не может быть объяснена через SHAP из-за низкого качества.\")\n",
        "    print(\"Рекомендуется обучить более мощную модель (XGBoost/Random Forest).\")\n",
        "else:\n",
        "    print(f\"✅ SHAP значения успешно вычислены. Диапазон: [{shap_values.min():.4f}, {shap_values.max():.4f}]\")\n",
        "\n",
        "# 4. ВИЗУАЛИЗАЦИИ\n",
        "\n",
        "# 4.1 Bar Plot - глобальная важность признаков\n",
        "print(\"\\nГенерация SHAP Summary Plot (Bar)...\")\n",
        "plt.figure(figsize=(10, 8))\n",
        "shap.summary_plot(\n",
        "    shap_values,\n",
        "    X_test_sample,\n",
        "    feature_names=X.columns.tolist(),\n",
        "    plot_type=\"bar\",\n",
        "    show=False\n",
        ")\n",
        "plt.title(\"Глобальная важность признаков (SHAP)\")\n",
        "plt.xlabel(\"Среднее абсолютное значение SHAP\")\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# 4.2 Dot Plot - распределение влияния признаков\n",
        "print(\"\\nГенерация SHAP Summary Plot (Dot)...\")\n",
        "plt.figure(figsize=(10, 8))\n",
        "shap.summary_plot(\n",
        "    shap_values,\n",
        "    X_test_sample,\n",
        "    feature_names=X.columns.tolist(),\n",
        "    show=False\n",
        ")\n",
        "plt.title(\"Распределение SHAP значений по признакам\")\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# 4.3 ТОП-10 признаков с таблицей\n",
        "print(\"\\n--- ТОП-10 важнейших признаков ---\")\n",
        "shap_importance = np.abs(shap_values).mean(axis=0)\n",
        "feature_importance = pd.DataFrame({\n",
        "    'Feature': X.columns.tolist(),\n",
        "    'Mean |SHAP|': shap_importance\n",
        "}).sort_values('Mean |SHAP|', ascending=False)\n",
        "\n",
        "print(feature_importance.head(10).to_string(index=False))\n",
        "\n",
        "# 4.4 Force Plot для экземпляра с максимальной ошибкой\n",
        "print(\"\\nГенерация SHAP Force Plot для экземпляра с максимальной ошибкой...\")\n",
        "\n",
        "# Находим экземпляр с максимальной ошибкой\n",
        "errors = abs(y_test.loc[X_test_sample.index] - svm_model.predict(X_test_sample))\n",
        "max_error_idx = errors.idxmax()\n",
        "max_error_instance = X_test_sample.loc[[max_error_idx]]\n",
        "max_error_shap = shap_values[X_test_sample.index.get_loc(max_error_idx)]\n",
        "\n",
        "actual_value = y_test.loc[max_error_idx]\n",
        "predicted_value = svm_model.predict(max_error_instance)[0]\n",
        "\n",
        "print(f\"Экземпляр с макс. ошибкой (индекс {max_error_idx}):\")\n",
        "print(f\"  Факт: {actual_value:.2f}\")\n",
        "print(f\"  Предсказание: {predicted_value:.2f}\")\n",
        "print(f\"  Ошибка: {abs(actual_value - predicted_value):.2f}\")\n",
        "print(f\"  Базовое значение (expected): {explainer.expected_value:.2f}\")\n",
        "\n",
        "# Проверяем, что SHAP сумма равна разнице между предсказанием и базовым значением\n",
        "sum_shap = np.sum(max_error_shap)\n",
        "print(f\"  Сумма SHAP значений: {sum_shap:.4f}\")\n",
        "print(f\"  Предсказание = базовое + сумма SHAP: {explainer.expected_value:.2f} + {sum_shap:.4f} = {explainer.expected_value + sum_shap:.2f}\")\n",
        "\n",
        "# Force Plot\n",
        "try:\n",
        "    shap.force_plot(\n",
        "        explainer.expected_value,\n",
        "        max_error_shap,\n",
        "        max_error_instance.values[0],\n",
        "        feature_names=X.columns.tolist(),\n",
        "        matplotlib=True,\n",
        "        show=False\n",
        "    )\n",
        "    plt.title(f\"SHAP Force Plot для экземпляра с макс. ошибкой\\n(Факт: {actual_value:.2f}, Пред: {predicted_value:.2f})\")\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "except Exception as e:\n",
        "    print(f\"Force Plot не сработал: {e}\")\n",
        "\n",
        "    # Waterfall Plot как альтернатива\n",
        "    try:\n",
        "        print(\"Используем Waterfall Plot...\")\n",
        "        shap.waterfall_plot(\n",
        "            shap.Explanation(\n",
        "                values=max_error_shap,\n",
        "                base_values=explainer.expected_value,\n",
        "                data=max_error_instance.values[0],\n",
        "                feature_names=X.columns.tolist()\n",
        "            ),\n",
        "            show=False\n",
        "        )\n",
        "        plt.title(f\"SHAP Waterfall Plot для экземпляра с макс. ошибкой\")\n",
        "        plt.tight_layout()\n",
        "        plt.show()\n",
        "    except Exception as e2:\n",
        "        print(f\"Waterfall Plot тоже не сработал: {e2}\")\n",
        "\n",
        "print(\"\\n✅ SHAP анализ завершен!\")"
      ],
