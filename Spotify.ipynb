      "source": [
        "### Feature Selection: Filtering by Correlation with Targe\n",
        "Отберем признаки, у которых модуль коэффициента корреляции с целевой переменной `popularity_capped` превышает 0,03. Цель этого шага — сохранить только наиболее значимые признаки для прогнозирования популярности."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "68379371",
        "outputId": "d9cd3243-a33e-47b6-d369-88bcac55861c"
      },
      "source": [
        "import numpy as np\n",
        "\n",
        "# Calculate the absolute correlation of all features with 'popularity_capped'\n",
        "absolute_correlations = df_final.corrwith(df_final['popularity_capped']).abs().sort_values(ascending=False)\n",
        "\n",
        "# Define the correlation threshold\n",
        "correlation_threshold = 0.03\n",
        "\n",
        "# Get features with absolute correlation greater than the threshold\n",
        "selected_features_by_corr = absolute_correlations[absolute_correlations > correlation_threshold].index.tolist()\n",
        "\n",
        "# Ensure the target variable itself is included in the selected features\n",
        "if 'popularity_capped' not in selected_features_by_corr:\n",
        "    selected_features_by_corr.append('popularity_capped')\n",
        "\n",
        "print(f\"Features selected based on absolute correlation > {correlation_threshold} with 'popularity_capped':\")\n",
        "for feature in selected_features_by_corr:\n",
        "    print(f\"- {feature}: {absolute_correlations[feature]:.4f}\")\n",
        "\n",
        "# Create a new DataFrame with only the selected features\n",
        "df_final_selected = df_final[selected_features_by_corr].copy()\n",
        "\n",
        "print(f\"\\nShape of df_final_selected after correlation-based feature selection: {df_final_selected.shape}\")\n",
        "print(\"Info of the selected DataFrame:\")\n",
        "df_final_selected.info()\n"
      ],
