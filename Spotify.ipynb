      "source": [
        "# Capping for 'duration_ms'\n",
        "Q1_duration = df['duration_ms'].quantile(0.25)\n",
        "Q3_duration = df['duration_ms'].quantile(0.75)\n",
        "IQR_duration = Q3_duration - Q1_duration\n",
        "\n",
        "lower_bound_duration = Q1_duration - 1.5 * IQR_duration\n",
        "upper_bound_duration = Q3_duration + 1.5 * IQR_duration\n",
        "\n",
        "print(f\"Original 'duration_ms' - Q1: {Q1_duration:.2f}, Q3: {Q3_duration:.2f}, IQR: {IQR_duration:.2f}\")\n",
        "print(f\"Lower Bound for Capping: {lower_bound_duration:.2f}, Upper Bound for Capping: {upper_bound_duration:.2f}\")\n",
        "\n",
        "df['duration_ms_capped'] = df['duration_ms'].clip(lower=lower_bound_duration, upper=upper_bound_duration)\n",
        "\n",
        "print(\"\\nDescriptive statistics for 'duration_ms' after capping:\")\n",
        "display(df[['duration_ms', 'duration_ms_capped']].describe())\n",
        "\n",
        "# Visualize 'duration_ms' after capping\n",
        "plt.figure(figsize=(10, 6))\n",
        "sns.boxplot(y=df['duration_ms_capped'])\n",
        "plt.title('Box Plot of Duration (After Outlier Capping)')\n",
        "plt.ylabel('Duration (Capped)')\n",
        "plt.show()\n",
        "\n",
        "print(f\"Number of values changed due to capping in 'duration_ms': {(df['duration_ms'] != df['duration_ms_capped']).sum()}\")"
      ],
