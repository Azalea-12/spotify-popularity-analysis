        "### Визуализация результатов SHAP анализа\n",
        "\n",
        "Теперь, когда у нас есть SHAP-значения, мы можем визуализировать их для получения инсайтов о работе модели. Мы используем следующие типы графиков:"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 1000
        },
        "id": "f45f3484",
        "outputId": "62d6ff54-5f3d-452b-dfa3-bba025bf9c7f"
      },
      "source": [
        "# 1. Summary Plot (сводный график) - показывает важность каждого признака и его влияние на предсказания\n",
        "print(\"Генерация SHAP Summary Plot...\")\n",
        "plt.figure(figsize=(12, 8))\n",
        "shap.summary_plot(\n",
        "    shap_values,\n",
        "    X_test_sample,\n",
        "    feature_names=X.columns.tolist(),\n",
        "    plot_type=\"bar\",\n",
        "    show=False            # ✅ Не показываем сразу, чтобы добавить заголовок\n",
        ")\n",
        "plt.title(\"SHAP Summary Plot (Bar) - Важность признаков\")\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# 2. Summary Plot (dot plot) - показывает распределение SHAP-значений для каждого признака\n",
        "# Цвет точек указывает на значение признака (красный = высокое, синий = низкое)\n",
        "print(\"Генерация SHAP Summary Plot (Dot)...\")\n",
        "shap.summary_plot(shap_values, X_test_sample, show=False)\n",
        "plt.title(\"SHAP Summary Plot (Dot)\")\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# 3. Force Plot для одного экземпляра - объясняет предсказание отдельного примера\n",
        "print(\"Генерация SHAP Force Plot для первого экземпляра...\")\n",
        "# Выберем первый пример из нашей выборки для объяснения\n",
        "i = 0\n",
        "sample_data = X_test_sample.iloc[i]\n",
        "sample_shap = shap_values[i]\n",
        "\n",
        "print(f\"Пример #{i}:\")\n",
        "print(f\"  Реальная популярность: {y_test.iloc[i]:.2f}\")\n",
        "print(f\"  Предсказанная популярность: {svm_model.predict(X_test.iloc[[i]])[0]:.2f}\")\n",
        "print(f\"  Базовое значение: {explainer.expected_value:.2f}\")\n",
        "\n",
        "# Force Plot (может не работать в некоторых версиях shap)\n",
        "try:\n",
        "    # Современный способ\n",
        "    shap.force_plot(\n",
        "        explainer.expected_value,\n",
        "        sample_shap,\n",
        "        sample_data,\n",
        "        feature_names=X.columns.tolist(),\n",
        "        matplotlib=True,\n",
        "        show=False\n",
        "    )\n",
        "    plt.title(f\"SHAP Force Plot для примера #{i}\")\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "except Exception as e:\n",
        "    print(f\"Force Plot не сработал: {e}\")\n",
        "\n",
        "    # Альтернатива: Waterfall Plot\n",
        "    try:\n",
        "        print(\"Используем Waterfall Plot...\")\n",
        "        shap.waterfall_plot(\n",
        "            shap.Explanation(\n",
        "                values=sample_shap,\n",
        "                base_values=explainer.expected_value,\n",
        "                data=sample_data,\n",
        "                feature_names=X.columns.tolist()\n",
        "            ),\n",
        "            show=False\n",
        "        )\n",
        "        plt.title(f\"SHAP Waterfall Plot для примера #{i}\")\n",
        "        plt.tight_layout()\n",
        "        plt.show()\n",
        "    except Exception as e2:\n",
        "        print(f\"Waterfall Plot тоже не сработал: {e2}\")\n",
        "print(\"SHAP анализ завершен. Визуализации должны помочь понять влияние признаков.\")"
      ],
